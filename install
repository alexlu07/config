#!/usr/bin/env bash

set -e

DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Detect OS
OS=$(uname -s)
[ "$OS" = "Darwin" ] && TAG="mac" || TAG="linux"

# Generate OS-specific configs from templates/
echo "Generating configs for: $TAG"
mkdir -p "${BASEDIR}/configs"

process_file() {
    local src="$1" dst="$2"
    awk -v os="$TAG" '
        /^#=+ [A-Z]+ =+/ {
            tag = tolower($2)
            if (tag == "end") { skip = 0 }
            else { skip = (tag != os) }
            next
        }
        !skip { print }
    ' "$src" > "$dst"
}

process_dir() {
    local src="$1" dst="$2"
    mkdir -p "$dst"
    for entry in "$src"/*; do
        [ -e "$entry" ] || continue
        local name; name=$(basename "$entry")
        if [ -d "$entry" ]; then
            process_dir "$entry" "$dst/$name"
        else
            process_file "$entry" "$dst/$name"
        fi
    done
}

for src in "${BASEDIR}"/templates/*; do
    name=$(basename "$src")
    if [ -d "$src" ]; then
        process_dir "$src" "${BASEDIR}/configs/$name"
    else
        process_file "$src" "${BASEDIR}/configs/$name"
    fi
done
chmod +x "${BASEDIR}/configs/requirements"
find "${BASEDIR}/configs" -name "*.sh" -exec chmod +x {} \;
echo "  configs/ generated"

# Install dependencies
bash "${BASEDIR}/configs/requirements"

# Init dotbot submodule
cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

# Symlink configs
"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "configs/install.conf.yaml" "${@}"

# Init conda shell integration
source ~/miniconda3/bin/activate
conda init --all

# Install VSCode extension
if command -v code &> /dev/null; then
    echo "Installing VSCode extensions"
    code --install-extension alexlu07.vscode-pathfinder
else
    echo "VSCode is not installed, skipping extension installation."
fi
